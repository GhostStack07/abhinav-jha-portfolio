# Email notifications (optional — leave blank to skip)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
NOTIFY_EMAIL="connect@abhinavjha.com"
