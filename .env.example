# Database (SQLite — file path relative to /prisma/)
DATABASE_URL="file:./dev.db"

# Site URL (used in email notifications)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin CRM password (leave blank to disable auth in dev)
